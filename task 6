#include <stdio.h>

float totalRevenue(float bills[], int n);
int bestTable(float bills[], int n);
int isProfitable(float total);

int main() {
    float bills[5], total;
    int i, best;

    printf("Enter 5 table bills: ");
    for(i = 0; i < 5; i++)
        scanf("%f", &bills[i]);

    total = totalRevenue(bills, 5);
    best = bestTable(bills, 5);

    printf("Total Revenue: %.2f\n", total);
    printf("Best Table: %d\n", best + 1);

    if(isProfitable(total))
        printf("Profitable night");
    else
        printf("Not profitable");

    return 0;
}

float totalRevenue(float bills[], int n) {
    int i;
    float sum = 0;
    for(i = 0; i < n; i++)
        sum += bills[i];
    return sum;
}

int bestTable(float bills[], int n) {
    int i, idx = 0;
    for(i = 1; i < n; i++)
        if(bills[i] > bills[idx])
            idx = i;
    return idx;
}

int isProfitable(float total) {
    if(total > 10000) return 1;
    else return 0;
}
